# ==============================================================================
#                       Navix 环境变量配置说明
# ==============================================================================

# --- 💾 数据库配置 ---
# 定义后端程序使用的数据库连接地址，**必填**。
#
# 示例：
#   - SQLite:  DATABASE_URL="sqlite:.navix-dev/database/navix-server.db"
#     ⚠️ 注意：请定期备份该数据库文件！
DATABASE_URL=""

# --- 🔐 安全配置 ---
# 用于签发和验证 JWT（JSON Web Token）的密钥。
# ⚠️ **强烈建议** 修改为一个长且难以预测的随机字符串。
#
# 示例：
# JWT_SECRET="your-super-secret-and-long-random-string-that-no-one-can-guess"

# --- 🌐 服务端口配置（可选） ---
# 用于配置 HTTP 和 HTTPS 服务的监听端口。如果未设置，将使用默认值。

# HTTP 服务端口（默认: 9990）
# HTTP_PORT=9990

# HTTPS 服务端口（默认: 9991，仅启用 HTTPS 时生效）
# HTTPS_PORT=9991

# --- 🔒 TLS / SSL 证书配置（可选） ---
# 如需启用 HTTPS，必须提供有效的证书路径和私钥路径。
#
# ⚠️ 注意事项：
#   - 文件必须是 `.pem` 格式
#   - **不要使用 Windows 风格的反斜杠路径**（例如 `C:\path\to\file.pem`）
#   - 建议使用双反斜杠（`\\`）或正斜杠（`/`）格式，如：
#       TLS_CERT_PATH=C:/Users/you/certs/cert.pem

# SSL 证书路径（启用 HTTPS 时必填）
# TLS_CERT_PATH=""

# SSL 私钥路径（启用 HTTPS 时必填）
# TLS_KEY_PATH=""

# --- 🪵 日志配置（可选） ---
# 设置日志等级（默认: info）。支持值包括：trace, debug, info, warn, error
# RUST_LOG="info"
